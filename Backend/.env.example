# Groq LLM (free tier: https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# JWT signing — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string

DATABASE_URL=sqlite:///./app.db

# Comma-separated frontend URLs allowed by CORS (add your Vercel URL after deploy)
# Example after Vercel: https://multidocrag.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
